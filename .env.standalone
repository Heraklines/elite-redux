# Elite Redux — standalone / public deploy (#218).
# Backend-less build for free static hosting (Cloudflare Pages). Run:
#   pnpm build:standalone
# See docs/plans/er-hosting-cloudflare.md for the full deploy guide.

# Guest mode: no PokeRogue account server required; saves live in localStorage.
VITE_BYPASS_LOGIN=1
VITE_BYPASS_TUTORIAL=0
VITE_I18N_DEBUG=0

# Unused in Guest mode, but the type expects a URL. Leave as-is.
VITE_SERVER_URL=https://api.pokerogue.net

# OAuth client IDs are unused in Guest mode; placeholders are fine.
VITE_DISCORD_CLIENT_ID=placeholder
VITE_GOOGLE_CLIENT_ID=placeholder

# --- Optional Elite Redux integrations (leave blank to disable) -------------

# Cross-player ghost-team API (#217) — your deployed Worker's /ghost URL.
# Blank = ghosts fall back to the player's own local winning teams.
# VITE_GHOST_ENDPOINT=https://er-ghost-api.<your-subdomain>.workers.dev/ghost

# In-game bug reporter (#220) — a form-to-email relay (e.g. Web3Forms submit URL)
# so reports reach your inbox without the player needing an account. Blank = the
# reporter still works locally (copies to clipboard + downloads a .json file).
# VITE_BUGREPORT_ENDPOINT=https://api.web3forms.com/submit
# VITE_BUGREPORT_KEY=your-web3forms-access-key

# Story Mode (LLM Director, #219) stays hidden ("Coming Soon") unless both of
# these are set. Leave blank for a public build.
# VITE_NANOGPT_API_KEY=
# VITE_NANOGPT_BASE_URL=
