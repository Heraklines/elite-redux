# Cloudflare Pages cache rules.
#
# Goal: force every client to pick up a new deploy IMMEDIATELY (no "poisoned"
# stale JavaScript) WITHOUT ever asking players to clear site data — clearing
# site data wipes localStorage, which is where runs/saves live.
#
# Strategy: always-revalidate the entry point + the cache-buster manifests, and
# let the content-hashed build output cache forever (a new build changes the
# hashed filenames, so old caches simply stop being referenced).

# Entry HTML — revalidate on every load so a fresh deploy is served right away.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache

# Asset-timestamp manifest (drives the ?t= cache-buster) + PWA web manifest.
# These MUST be fresh, or clients keep resolving assets with stale timestamps.
/manifest.json
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache

# Vite build output is content-hashed (filename changes when content changes),
# so it is safe to cache permanently.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
